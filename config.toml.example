# ─────────────────────────────────────────────────────
#  NetPulse – Configuration File
# ─────────────────────────────────────────────────────

[panel]
host = "127.0.0.1"
port = 7070
username = "admin"
password = "admin123"
secret_key = "change-me-to-a-random-string"

[scheduler]
days = 0   # 0 = run forever
daily_variance = 0.20
schedule_weights = [0.05, 0.30, 0.35, 0.30]

[download]
speed_cap = 5242880          # 5 MB/s per download (0 = unlimited)
pause_probability = 0.3
pause_range = [10, 90]
max_concurrent = 2

[network]
verify_ssl = false           # false for self-signed certificates

[logging]
level = "INFO"
file = "logs/netpulse.log"

# ── Download Sources (VPN servers) ────────────────────────────────────────────
# monthly_limit_gb  : total monthly quota for this server
# usage_quota_pct   : fraction allowed for downloads (0.6 = 60%)
# The system will prioritise servers with the most remaining quota.

[[sources]]
label = "server1"
download_url = "https://192.168.1.100/files/1gb.zip"
metric_url = "https://192.168.1.100/your-metric-token-here"

[[sources]]
label = "server2"
download_url = "https://192.168.1.200/files/1gb.zip"
metric_url = "https://192.168.1.200/your-metric-token-here"

# ── Monitor-only Sources ──────────────────────────────────────────────────────
# These servers are monitored for metrics but never used for downloads.

[[monitors]]
label = "monitor1"
metric_url = "https:/192.168.1/your-metric-token-here"

# ── Agent Servers ─────────────────────────────────────────────────────────────
# Use host = "localhost" to make the coordinator itself act as an agent.

[[agents]]
label = "self"
host = "localhost"
port = 0
user = "local"
password = "local"
daily_limit_gb = 8.0
monthly_limit_gb = 100.0
usage_quota_pct = 0.60       # use at most 60 GB this month

[[agents]]
label = "agent1"
host = "192.168.1.10"
port = 22
user = "root"
password = "secret"
daily_limit_gb = 5.0
monthly_limit_gb = 100.0
usage_quota_pct = 0.60

[[agents]]
label = "agent2"
host = "192.168.1.11"
port = 22
user = "root"
password = "secret"
daily_limit_gb = 10.0
monthly_limit_gb = 100.0
usage_quota_pct = 0.60